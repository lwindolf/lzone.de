{
    "name": "lzone.de",
    "version": "0.9.0",
    "description": "Content aggregator for feeds and markdown content",
    "type": "module",
    "scripts": {
        "test": "eslint --ignore-pattern vendor src/js && NODE_OPTIONS=--experimental-require-module npx jest --coverage",
        "start": "cd www && npx serve",
        "startDev": "cd src && npx serve -S",
        "build": "./build.sh"
    },
    "dependencies": {
        "asciidoctor": "^3.0.3",
        "dompurify": "^3.2.3",
        "handlebars": "^4.7.8",
        "lunr": "^2.3.6",
        "mermaid": "^11.12.3",
        "pdfjs-dist": "^5.2.133",
        "rst2html": "^1.0.0",
        "split.js": "^1.6.5",
        "webamp": "^1.5.0"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.22.20",
        "babel-jest": "^29.7.0",
        "eslint": "^8.49.0",
        "fake-indexeddb": "^6.0.1",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^30.2.0",
        "whatwg-fetch": "^3.6.19"
    },
    "jest": {
        "verbose": true,
        "transform": {
            "^.+\\.js?$": "babel-jest"
        },
        "testEnvironment": "jest-environment-jsdom",
        "roots": [
            "./tests"
        ],
        "setupFiles": [
            "./tests/global.mock.js"
        ]
    }
}
